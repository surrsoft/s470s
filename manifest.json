{
  "manifest_version": 3,
  "name": "s470s",
  "version": "1.0.0",
  "description": "Quick copy notes — click to copy, organize your snippets",
  "permissions": ["storage", "clipboardWrite"],
  "host_permissions": ["https://*.supabase.co/*"],
  "options_ui": {
    "page": "settings.html",
    "open_in_tab": true
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
